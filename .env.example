# Webflow API token — needs cms:read (for the CMS endpoints) and sites:read (for CORS custom-domain lookup)
WEBFLOW_API_TOKEN=your_webflow_api_token_here

# Webflow site ID — used by `npm run schema` and by CORS (custom domains)
WEBFLOW_SITE_ID=your_webflow_site_id_here

# CDN cache: how long (seconds) a shared cache may serve the response as-fresh
CACHE_MAX_AGE=60

# CDN cache: how long (seconds) a stale response may still be served while revalidating
CACHE_STALE_WHILE_REVALIDATE=300

# Path to the endpoints config file (relative to project root)
ENDPOINTS_CONFIG=./config/endpoints.json
