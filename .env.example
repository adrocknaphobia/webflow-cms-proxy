# Webflow Data API token (CMS read access — keep secret)
WEBFLOW_API_TOKEN=your_webflow_api_token_here

# Webflow site ID (found in Site Settings → General)
WEBFLOW_SITE_ID=your_webflow_site_id_here

# Webflow Sites API token (sites:read scope — used by CORS to fetch custom domains)
WEBFLOW_SITE_API_TOKEN=your_webflow_site_api_token_here

# Webflow CMS collection ID
WEBFLOW_COLLECTION_ID=your_collection_id_here

# CMS field API slug holding the YouTube video ID
YOUTUBE_FIELD_NAME=VideoID

# CDN cache: how long (seconds) a shared cache may serve the response as-fresh
CACHE_MAX_AGE=60

# CDN cache: how long (seconds) a stale response may still be served while revalidating
CACHE_STALE_WHILE_REVALIDATE=300
